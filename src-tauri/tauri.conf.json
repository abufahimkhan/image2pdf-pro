{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image2PDF Pro",
  "version": "2.4.0",
  "identifier": "com.image2pdf.pro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Image2PDF Pro - Professional Layout Suite",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["all"],
    "windows": {
      "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": "always",
        "createStartMenuShortcut": "always",
        "shortcutName": "Image2PDF Pro",
        "languages": ["English"],
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
